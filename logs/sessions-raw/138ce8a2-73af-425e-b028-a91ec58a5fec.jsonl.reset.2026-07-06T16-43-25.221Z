gbbuXvspwACKRhrG9xsWUqK7nUazM_kRgEAAwIAA20AAzwE\",\"file_unique_id\":\"AQADKRhrG9xsWUpy\",\"file_size\":14504,\"width\":320,\"height\":320},{\"file_id\":\"AgACAgIAAxkDAAIByWpKpJM0lutWsAABvMioPgbbuXvspwACKRhrG9xsWUqK7nUazM_kRgEAAwIAA3gAAzwE\",\"file_unique_id\":\"AQADKRhrG9xsWUp9\",\"file_size\":56112,\"width\":800,\"height\":800},{\"file_id\":\"AgACAgIAAxkDAAIByWpKpJM0lutWsAABvMioPgbbuXvspwACKRhrG9xsWUqK7nUazM_kRgEAAwIAA3kAAzwE\",\"file_unique_id\":\"AQADKRhrG9xsWUp-\",\"file_size\":80407,\"width\":1024,\"height\":1024}],\"caption\":\"\\ud83c\\udfa8 Generated image for your AI testing post\"}}","cwd":"/data/workspace"},"isError":false,"timestamp":1783276692164}}
