]; then\\n  CADENCE=$(grep -i \\\"cadence\\\\|frequency\\\\|per week\\\\|posts/week\\\" \\\"$BASE/strategy.md\\\" | head -1 | sed 's/.*: //')\\nfi\\n\\n# Posts in last 7 days\\nPOST_COUNT=$(find \\\"$BASE/posts/\\\" -name \\\"*.md\\\" -newer \\\"$(date -d '7 days ago' +%Y-%m-%d)\\\" 2>/dev/null | wc -l | tr -d ' ')\\n\\n# Days since last post\\nLAST_POST_DATE=$(ls -t \\\"$BASE/posts/\\\"*.md 2>/dev/null | head -1 | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}')\\nTODAY=$(date +%Y-%m-%d)\\n\\n# Next calendar idea\\nNEXT_IDEA=\\\"\\\"\\nif [ -f \\\"$BASE/content-calendar.md\\\" ]; then\\n  NEXT_IDEA=$(grep -A2 \\\"Status.*Planned\\\\|Status.*planned\\\\|\\\\[ \\\\]\\\" \\\"$BASE/content-calendar.md\\\" 2>/dev/null | head -5)\\nfi\\n\\necho \\\"NAME=$DISPLAY_NAME\\\"\\necho \\\"CADENCE=$CADENCE\\\"\\necho \\\"POSTS_LAST_7=$POST_COUNT\\\"\\necho \\\"LAST_POST=$LAST_POST_DATE\\\"\\necho \\\"TODAY=$TODAY\\\"\\necho \\\"NEXT_IDEA_BLOCK=$NEXT_IDEA\\\"\"}"},{"type":"toolCall","id":"call_5b1abd353d924ded84ea1cc5","name":"read","arguments":{"path":"/data/workspace/social/linkedin/264468965/content-calendar.md"},"partialArgs":"{\"path\": \"/data/workspace/social/linkedin/264468965/content-calendar.md\"}"}],"api":"openai-completions","provider":"litellm","model":"vertex_ai/zai-org/glm-5-maas","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783435434622,"responseId":"qxBNauT3OYqM6dgPkLuekAM"}}
