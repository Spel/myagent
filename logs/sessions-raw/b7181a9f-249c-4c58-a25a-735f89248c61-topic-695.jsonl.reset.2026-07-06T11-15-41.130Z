{"type":"message","id":"82915593-9a68-42cd-8a83-47207c5b07f7","parentId":"916f3796-176c-4eb0-9277-c7af2ddb99ea","timestamp":"2026-07-03T15:01:28.244Z","message":{"role":"assistant","content":[{"type":"text","text":"✅ **Brand voice profile saved!**\n\nТепер всі пости будуть у твоєму стилі — легкий, гумористичний, мотиваційний з практичними tips.\n\nПублікую твій пост..."}],"api":"openai-responses","provider":"openclaw","model":"delivery-mirror","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"stop","timestamp":1783090888233,"openclawDeliveryMirror":{"kind":"channel-final","sourceMessageId":"telegram-final:agent:main:telegram:group:-1003910747757:topic:695:-1003910747757:814:1"},"idempotencyKey":"telegram-final:agent:main:telegram:group:-1003910747757:topic:695:-1003910747757:814:1"}}
