TS_TODAY=$POSTS_TODAY\\\"\"}"}],"api":"openai-completions","provider":"litellm","model":"vertex_ai/zai-org/glm-5-maas","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1783383248111,"responseId":"0URMapTKO7-S6dgPqeLdoAI"}}
